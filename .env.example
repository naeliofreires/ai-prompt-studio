# Copy to `.env` in the project root for local development (`npm run dev` loads it in the Electron main process only when the app is not packaged).

# Google Gemini (https://ai.google.dev/gemini-api/docs/api-key)
GOOGLE_GENERATIVE_AI_API_KEY=

# Z.ai / Zhipu GLM — OpenAI-compatible API. Default base URL is https://api.z.ai/api/paas/v4/ (Z.ai).
# Create keys at https://z.ai/manage-apikey/apikey-list — use either variable name below; GLM_API_KEY is preferred.
GLM_API_KEY=
# ZHIPU_API_KEY=

# Optional: override GLM base URL (e.g. legacy BigModel CN: https://open.bigmodel.cn/api/paas/v4/)
# GLM_BASE_URL=

# DeepSeek (https://platform.deepseek.com) — OpenAI-compatible HTTP API. Default base URL is https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
# Optional: override API base URL
# DEEPSEEK_BASE_URL=

# OpenCode Zen (https://opencode.ai/zen) — OpenAI-compatible HTTP API. Default base URL is https://opencode.ai/zen/v1
OPENCODE_API_KEY=
# Optional: override API base URL (preferred)
# OPENCODE_ZEN_BASE_URL=
# Legacy compatibility alias: OPENCODE_BASE_URL=
