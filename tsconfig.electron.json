{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist-electron",
    "types": ["node"],
    "declaration": false,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "src/main/**/*.ts",
    "apps/promptizer/main/**/*.ts",
    "apps/promptizer/shared/**/*.ts",
    "apps/promptizer/spec/personas.json",
    "apps/promptizer/spec/providers.json"
  ]
}
